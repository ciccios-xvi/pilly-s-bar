<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>Bar Pilly</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: #f4f4f4;
      text-align: center;
    }
    header {
      background-color: #222;
      color: white;
      padding: 20px;
    }
    h1 {
      margin: 0;
    }
    .container {
      padding: 20px;
    }
    .menu {
      background: white;
      margin: 20px auto;
      padding: 20px;
      max-width: 500px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    button {
      padding: 15px 25px;
      font-size: 16px;
      background-color: #ff9800;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }
    button:hover {
      background-color: #e68900;
    }
    footer {
      margin-top: 30px;
      font-size: 12px;
      color: gray;
    }
  </style>
</head>

<body>

<header>
  <h1>🍻 Bar Pilly</h1>
  <p>Dal 1987 (forse)</p>
</header>

<div class="container">

  <div class="menu">
    <h2>📋 Menu</h2>
    <p>Spritz all'aria – 12€</p>
    <p>Acqua frizzante senza acqua – 8€</p>
    <p>Caffè lungo 3 ore – 5€</p>
    <p>Panino invisibile – 15€</p>
  </div>

  <div class="menu">
    <h2>⭐ Recensioni</h2>
    <p>"Non sono mai stato ma 5 stelle" – Marco</p>
    <p>"Ho pagato e basta" – Giulia</p>
    <p>"Esperienza mistica" – Uno a caso</p>
  </div>

  <button onclick="prenota()">Prenota ora</button>

</div>

<footer>
  <p>© Bar Pilly - Tutti i diritti riservati (non proprio)</p>
</footer>

<script>
function prenota() {
  alert("Prenotazione confermata! Porta 50€ in contanti 😄");
}

setTimeout(() => {
  alert("🎉 Complimenti! Hai vinto uno spritz gratuito!");
}, 3000);

setTimeout(() => {
  alert("...ah no scherzo 😂");
}, 6000);
</script>

</body>
</html>
